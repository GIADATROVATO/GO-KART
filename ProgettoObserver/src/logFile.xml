<?xml version="1.0" encoding="UTF-8"?>
<Configuration status= "INFO" name="MyConfigApp">  
 <!-- il campo status=INFO serve per vedere i messaggi di Log4jz stesso(utile per debug di configurazione -->
	<Appenders> 
		<!-- 1 console appender -->
		<Console target="SYSTEM_OUT" name="ConsoleAppender">
			<PatternLayout pattern=""/>
		</Console>
		<!-- 2 Rolling File appender -->
	
		<RollingFile name="FileAppender"
				 	 fileName= "logs/app3.log"
					 PatternName= "logs/app3-%d{yyyy-MM-dd}.log">
				<PatternLayout pattern= "%d{yyyy-MM-dd HH:mm:ss} %-5p %c{1} - %m%n"/>	
				<Policies>
					<TimeBasedTriggeringPolicy interval="1"/>
					<SizeBasedTriggeringPolicy size="10MB"/>
				</Policies>  
		</RollingFile>
	</Appenders>
	
	<Loggers>
		<Root level= "debug">
		<AppendersRef ref = "ConsoleAppender"/>
		<AppendersRef ref= "FileAppender"/>
		</Root>
	</Loggers>
	
</Configuration>
